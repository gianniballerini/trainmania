doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title TrainMania
    link(rel='canonical' href='https://trainmania.gianniballerini.dev/')

    meta(name='description' content='A 3D puzzle game where you build train tracks to connect stations. Solve increasingly complex levels by placing track pieces on a grid, navigating around obstacles or picking coins, and optimizing routes. Built with Three.js and TypeScript')

    // Favicons
    link(rel='icon' type='image/png' href='/images/common/favicon.png')
    link(rel='apple-touch-icon' href='/images/common/apple-touch-icon.png')
    link(rel='manifest' href='/manifest.json')
    meta(name='theme-color' content='#FF6F61')

    // Open Graph
    meta(property='og:type' content='website')
    meta(property='og:url' content='https://trainmania.gianniballerini.dev/')
    meta(property='og:title' content='TrainMania')
    meta(property='og:description' content='A 3D puzzle game where you build train tracks to connect stations. Solve increasingly complex levels by placing track pieces on a grid, navigating around obstacles or picking coins, and optimizing routes. Built with Three.js and TypeScript')
    meta(property='og:image' content='https://trainmania.gianniballerini.dev/images/common/og-image-v2.jpg')
    meta(property='og:image:width' content='1200')
    meta(property='og:image:height' content='630')

    // Twitter Card
    meta(name='twitter:card' content='summary_large_image')
    meta(name='twitter:title' content='TrainMania')
    meta(name='twitter:description' content='A 3D puzzle game where you build train tracks to connect stations. Solve increasingly complex levels by placing track pieces on a grid, navigating around obstacles or picking coins, and optimizing routes. Built with Three.js and TypeScript')
    meta(name='twitter:image' content='https://trainmania.gianniballerini.dev/images/common/twitter-card-v2.jpg')

    link(rel='stylesheet' href='/src/style/main.scss')

  body
    .game
      include src/views/_canvas.pug
      include src/views/_hud.pug
      include src/views/_settings-modal.pug
      include src/views/_leaderboard-modal.pug
      include src/views/_global-score-modal.pug
      include src/views/_overlay.pug

    script(type='module' src='/main.ts')
